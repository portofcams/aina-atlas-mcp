# --- Āina Atlas MCP configuration ---
# Copy to .env (gitignored) and fill in. All values below are placeholders.

# Base URL of the live Āina Atlas data API (Node/Express "aina-atlas" service).
# This is a PUBLIC, keyless API — the default is correct for production.
AINA_BASE_URL=https://addressapi.portofcams.com

# OPTIONAL paid-tier bearer token. Anonymous access already returns the full
# free-tier parcel JSON, so this is only needed to unlock paid surfaces
# (e.g. the report PDF). Leave blank for the public lookup tools.
AINA_API_KEY=

# REQUIRED for the generate_property_brief tool. The brief is composed locally
# by this server (parcel JSON -> Anthropic Messages API), reusing the real
# Hawaii-property-analyst prompt. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: override the model used for the brief. Defaults to claude-opus-4-8.
AINA_BRIEF_MODEL=claude-opus-4-8
